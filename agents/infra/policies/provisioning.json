{
    "allowed_binaries": [
        "bash", "sh",
        "cat", "grep", "sed", "awk", "head", "tail", "wc", "sort", "tee", "tr", "cut",
        "echo", "printf", "test", "true", "false",
        "ls", "find", "stat", "file", "readlink",
        "mkdir", "chmod", "chown", "ln", "rm", "cp", "mv", "touch",
        "dnf", "yum", "rpm", "which",
        "curl", "wget",
        "git",
        "podman",
        "sudo",
        "systemctl", "setenforce", "getenforce",
        "ssh-keygen", "ssh", "scp",
        "k3s", "kubectl", "oc",
        "crucible", "zathras", "burden",
        "sleep", "xargs",
        "hostname", "uname", "nproc", "free", "lscpu",
        "cd"
    ],
    "blocked_patterns": [
        "\\bdd\\b.*\\bof\\s*=\\s*/dev/[sv]d",
        "\\bdd\\b.*\\bof\\s*=\\s*/dev/nvme",
        "\\bmkfs\\.",
        "\\bfdisk\\b",
        "\\bparted\\b",
        "\\bwipefs\\b",
        "\\brm\\s+-[^\\s]*r[^\\s]*f[^\\s]*\\s+/$",
        "\\b(?:docker|podman)\\s+run\\s+.*--privileged",
        "\\b(?:docker|podman)\\s+run\\s+.*-v\\s+/:/",
        "\\b(?:docker|podman)\\s+run\\s+.*--mount\\s+.*source=/[,\\s]"
    ],
    "max_timeout": 7200
}
