{
    "constraints": {
        "supported_os": ["rhel8", "rhel9", "rhel10", "centos"],
        "unsupported_os": ["ubuntu", "debian", "suse", "amazon", "fedora"],
        "os_reason": "Zathras install.sh requires dnf (not dnf5) and EPEL. Fedora 41+ ships dnf5 which breaks dnf config-manager --add-repo. Only RHEL 8+, and CentOS are supported.",
        "controller_os_must_match": false,
        "requires_epel": true,
        "epel_reason": "install.sh expects EPEL repository to be pre-configured for ansible-core and other packages.",
        "root_install_warning": "install.sh prompts for confirmation when run as root (EUID=0). Must pipe 'yes' or use a non-root user.",
        "notes": "These constraints are for cross-agent negotiation. The resource agent should verify the controller OS is RHEL/Fedora before assigning. The provisioning agent should ensure EPEL is enabled before running install.sh. If constraints cannot be met, agents should report the conflict to the ticket for user arbitration."
    },
    "execution": {
        "controller_required": true,
        "run_command": "/opt/zathras/bin/burden",
        "run_method": "scenario",
        "endpoint_type": "local",
        "endpoint_user": "root",
        "pre_run": ["ssh_key_setup"],
        "run_file_format": "yaml_scenario",
        "results_dir_pattern": "/tmp/results_*",
        "scenario_dir": "/opt/zathras",
        "local_configs_dir": "/opt/zathras/local_configs",
        "notes": "Zathras executes via scenario files. The benchmark agent should: (1) create a local_configs/<host>.config file on the controller with storage/network info, (2) create a scenario YAML file, (3) run burden --scenario <file>. For bare metal, system_type is 'local' and host_config is the hostname matching the local_configs file."
    },
    "provisioning": {
        "install_method": "git_clone",
        "git_url": "https://github.com/redhat-performance/zathras.git",
        "install_script": "bin/install.sh",
        "install_target_path": "/opt/zathras",
        "verify_command": "/opt/zathras/bin/burden --usage",
        "update_command": "cd /opt/zathras && git pull && bin/install.sh",
        "on_existing_install": "skip",
        "run_install_as_root": "yes | bin/install.sh",
        "pre_install_steps": [
            "dnf install -y epel-release || true",
            "dnf install -y git"
        ],
        "prerequisites_note": "install.sh handles most dependencies itself (ansible-core, jq, python3-pip, terraform, wget, unzip, boto, yq==2.10.0, ansible collections). The pre_install_steps ensure EPEL and git are available so install.sh can proceed. The prerequisites list below is what install.sh installs — listed here for agent awareness, not for pre-installation.",
        "prerequisites_installed_by_script": [
            "ansible-core",
            "git",
            "jq",
            "python",
            "python3-pip",
            "terraform",
            "unzip",
            "wget"
        ],
        "pip_packages_installed_by_script": [
            "boto",
            "boto3",
            "yq==2.10.0"
        ],
        "ansible_collections_installed_by_script": [
            "ansible.posix",
            "community.aws",
            "community.general",
            "amazon.aws==9.1.0"
        ],
        "post_install_notes": "install.sh uses pip --user, so ~/.local/bin must be in PATH. When running as root, this is /root/.local/bin."
    },
    "platform_contract": {
        "supported_os": ["rhel8", "rhel9", "rhel10", "centos"],
        "required_repos": ["epel"],
        "required_packages": ["git"]
    },
    "install_contract": {
        "secret_files": [],
        "pre_install_commands": [
            "dnf install -y epel-release || true",
            "dnf install -y git"
        ]
    },
    "scenario_template": {
        "notes": "Scenario files are YAML with 'global' and 'systems' sections. Options map directly to CLI flags without dashes. Each system block specifies tests, host_config, and optional overrides.",
        "bare_metal_example": {
            "global": {
                "results_prefix": "perf_test",
                "system_type": "local",
                "test_iter": 1
            },
            "systems": {
                "system1": {
                    "tests": "streams",
                    "host_config": "TARGET_HOST"
                }
            }
        },
        "global_fields": {
            "results_prefix": "Label for the results directory",
            "system_type": "local | aws | azure | gcp | ibm",
            "test_iter": "Number of test iterations (default: 1)",
            "ssh_key_file": "Path to SSH private key",
            "os_vendor": "rhel | ubuntu | amazon | suse",
            "tuned_profiles": "Comma-separated tuned profiles (RHEL only)",
            "tuned_reboot": "Set to 1 to reboot between tuned profile changes",
            "use_pcp": "0 or 1, toggle Performance Co-Pilot (default: 1)",
            "no_packages": "Skip all package installation",
            "upload_rpms": "Comma-separated paths to RPMs to install on target"
        },
        "system_fields": {
            "tests": "Test name(s), comma-separated (e.g., 'streams,fio')",
            "host_config": "Hostname matching local_configs/<hostname>.config",
            "tuned_profiles": "Override global tuned profiles for this system",
            "java_version": "java-8 | java-11 | java-17 | java-21"
        }
    },
    "local_config_format": {
        "notes": "For bare metal (system_type: local), create local_configs/<hostname>.config on the controller. The hostname must match the host_config value in the scenario. CPU-only tests (streams, linpack, coremark) need no fields — the file can be empty.",
        "fields": {
            "storage": "Comma-separated block devices (e.g., /dev/nvme0n1,/dev/nvme1n1). Required for fio, iozone, hammerdb, speccpu2017.",
            "server_ips": "Comma-separated IPs/hostnames for network test servers. Required for uperf.",
            "client_ips": "Comma-separated IPs/hostnames for network test clients. Required for uperf."
        },
        "example": "storage: /dev/nvme0n1,/dev/nvme1n1\nserver_ips: 192.168.1.100\nclient_ips: 192.168.1.101"
    },
    "tests": {
        "streams": {
            "description": "STREAM memory bandwidth benchmark. Measures sustainable memory bandwidth (MB/s) for Copy, Scale, Add, Triad operations.",
            "category": "memory",
            "wrapper_repo": "redhat-performance/streams-wrapper",
            "test_script": "streams_run",
            "requirements": {
                "storage": false,
                "network": false,
                "java": false
            },
            "parameters": {
                "--iterations": {
                    "type": "integer",
                    "default": 5,
                    "description": "Number of test iterations"
                }
            },
            "min_hosts": 1,
            "roles": ["client"],
            "local_config_fields": []
        },
        "linpack": {
            "description": "Standard LINPACK benchmark. Measures floating-point compute performance (GFLOPS).",
            "category": "cpu",
            "wrapper_repo": "redhat-performance/linpack-wrapper",
            "test_script": "linpack_run",
            "requirements": {
                "storage": false,
                "network": false,
                "java": false
            },
            "parameters": {
                "--interleave": {
                    "type": "string",
                    "default": "all",
                    "description": "NUMA memory interleave policy"
                },
                "--iterations": {
                    "type": "integer",
                    "default": 1,
                    "description": "Number of test iterations"
                }
            },
            "os_packages": {
                "rhel": ["bc", "numactl", "perf", "git", "unzip"],
                "ubuntu": ["unzip", "zip", "numactl"],
                "amazon": ["bc", "git", "zip", "unzip"]
            },
            "min_hosts": 1,
            "roles": ["client"],
            "local_config_fields": []
        },
