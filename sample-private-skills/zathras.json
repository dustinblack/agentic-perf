        "iozone": {
            "description": "IOzone filesystem benchmark. Tests read, write, re-read, re-write, random read/write across filesystems.",
            "category": "storage",
            "wrapper_repo": "redhat-performance/iozone-wrapper",
            "test_script": "iozone_run",
            "requirements": {
                "storage": true,
                "network": false,
                "java": false
            },
            "parameters": {
                "--devices_to_use": {
                    "type": "string",
                    "description": "Block devices. Populated from dyn_data.storage."
                },
                "--filesys": {
                    "type": "string",
                    "default": "xfs,ext4,ext3",
                    "description": "Comma-separated filesystems to test"
                },
                "--all_test": {
                    "type": "flag",
                    "default": true,
                    "description": "Run all IOzone test types"
                },
                "--mount_location": {
                    "type": "string",
                    "default": "/iozone/iozone0",
                    "description": "Mount point for test filesystems"
                },
                "--eatmem": {
                    "type": "flag",
                    "default": true,
                    "description": "Consume free memory to force I/O (avoid page cache effects)"
                },
                "--auto": {
                    "type": "flag",
                    "default": true,
                    "description": "Automatic mode"
                }
            },
            "min_hosts": 1,
            "roles": ["client"],
            "local_config_fields": ["storage"]
        },
        "uperf": {
            "description": "Unified Performance tool for network throughput and latency. Supports TCP/UDP with configurable message sizes, parallelism, and test patterns.",
            "category": "network",
            "wrapper_repo": "redhat-performance/uperf-wrapper",
            "test_script": "uperf_run",
            "requirements": {
                "storage": false,
                "network": true,
                "java": false
            },
            "parameters": {
                "--client_ips": {
                    "type": "string",
                    "description": "Client IP addresses. Populated from dyn_data.ct_uperf_client_list."
                },
                "--server_ips": {
                    "type": "string",
                    "description": "Server IP addresses. Populated from dyn_data.ct_uperf_server_ip."
                },
                "--tests": {
                    "type": "string",
                    "default": "stream,rr",
                    "description": "Test patterns: 'stream' (throughput), 'rr' (request-response latency), or both comma-separated"
                },
                "--numb_jobs": {
                    "type": "string",
                    "default": "1,8,16",
                    "description": "Comma-separated thread/process counts to test"
                },
                "--packet_type": {
                    "type": "string",
                    "default": "tcp",
                    "description": "Protocol: 'tcp' or 'udp'"
                },
                "--packet_sizes": {
                    "type": "string",
                    "default": "64,16384",
                    "description": "Comma-separated message sizes in bytes"
                },
                "--time": {
                    "type": "integer",
                    "default": 60,
                    "description": "Test duration in seconds per combination"
                }
            },
            "min_hosts": 2,
            "roles": ["client", "server"],
            "local_config_fields": ["server_ips", "client_ips"],
            "notes": "Requires at least 2 hosts: one client, one server. The local_config must have server_ips and client_ips. Zathras populates dyn_data.ct_uperf_server_ip and dyn_data.ct_uperf_client_list from these."
        },
