    "review": {
        "results_method": "ssh_file_read",
        "results_base_dir": "/opt/zathras",
        "results_path_hint": "Results are under the {results_prefix}/ directory on the controller. Look for subdirectories organized by OS/system_type/hostname. Within each, find ansible_log and benchmark wrapper output files.",
